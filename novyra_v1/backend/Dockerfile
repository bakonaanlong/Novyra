FROM python:3.12-slim

WORKDIR /srv

# System deps for scikit-learn/pandas wheels
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY app ./app
COPY Datasets ./Datasets

# Train models once at build time so the running container never trains
# on a request thread. Swap the CSVs in ./Datasets with real data before
# building if you have it — see Datasets/generate_sample_datasets.py.
RUN python -m app.train

EXPOSE 8000

# Fly.io and Railway both inject $PORT; default to 8000 for local runs.
ENV PORT=8000
CMD ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port ${PORT}"]
